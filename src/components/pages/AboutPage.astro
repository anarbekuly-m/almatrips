---
import Base from '../../layouts/Base.astro';
import { t, localizePath, waLink, type Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const copy = {
  en: {
    lead: 'A local travel company in Almaty, running group and private tours across Kazakhstan.',
    p1: 'Almatrips is a Kazakhstan-based travel company offering group and private tours from Almaty to the most beautiful destinations in the region — canyons, alpine lakes, mountains, nomad plateaus, national parks, city landmarks and cultural places.',
    p2: 'We help travelers choose the best route for their time, budget and travel style. Join a group for the best price, or book a private tour for your own pace — either way, our team takes care of the planning and the details.',
    p3: 'We work with experienced local guides and drivers who know the region well. Tours run in English and Russian, and we confirm every important detail with you on WhatsApp before the trip.',
    stats: [
      { n: '5+', l: 'years of experience' },
      { n: '15+', l: 'destinations around Almaty' },
      { n: 'EN / RU', l: 'guided tours' },
    ],
    valuesTitle: 'What we promise',
    values: [
      ['Honesty', 'We clearly explain each tour’s details before booking, so travelers know what to expect.'],
      ['Safety', 'We work with experienced guides and drivers to make every trip safe, organized and comfortable.'],
      ['Reliability', 'We keep communication clear and help travelers with all important details before the tour.'],
    ],
    cta: 'Message us on WhatsApp',
  },
  ru: {
    lead: 'Местная туркомпания в Алматы — групповые и индивидуальные туры по Казахстану.',
    p1: 'Almatrips — казахстанская туркомпания, которая проводит групповые и индивидуальные туры из Алматы к самым красивым местам региона: каньоны, горные озёра, горы, кочевые плато, нацпарки, городские достопримечательности и культурные места.',
    p2: 'Мы помогаем выбрать лучший маршрут под ваше время, бюджет и стиль путешествия. Присоединяйтесь к группе ради лучшей цены или берите индивидуальный тур в своём темпе — в любом случае планирование и детали берём на себя.',
    p3: 'Мы работаем с опытными местными гидами и водителями, которые хорошо знают регион. Туры проходят на английском и русском, а все важные детали мы подтверждаем с вами в WhatsApp до поездки.',
    stats: [
      { n: '5+', l: 'лет опыта' },
      { n: '15+', l: 'направлений вокруг Алматы' },
      { n: 'EN / RU', l: 'туры с гидом' },
    ],
    valuesTitle: 'Что мы обещаем',
    values: [
      ['Честность', 'Мы понятно объясняем детали каждого тура до брони, чтобы вы знали, чего ожидать.'],
      ['Безопасность', 'Мы работаем с опытными гидами и водителями, чтобы каждая поездка была безопасной, организованной и комфортной.'],
      ['Надёжность', 'Мы держим связь понятной и помогаем со всеми важными деталями до тура.'],
    ],
    cta: 'Написать в WhatsApp',
  },
}[lang];
---
<Base
  lang={lang}
  title={t(lang, 'meta.about.title')}
  description={t(lang, 'meta.about.description')}
  path="/about/"
>
  <div class="container page-head">
    <h1>{t(lang, 'about.title')}</h1>
    <p class="lead">{copy.lead}</p>
  </div>

  <section class="section" style="padding-top: 40px;">
    <div class="container about-body">
      <div>
        <p>{copy.p1}</p>
        <p>{copy.p2}</p>
        <p>{copy.p3}</p>
        <div class="stat-row">
          {copy.stats.map((s) => (
            <div class="stat"><strong>{s.n}</strong><span>{s.l}</span></div>
          ))}
        </div>
        <h2 style="font-size: 1.4rem;">{copy.valuesTitle}</h2>
        <div class="why-grid" style="margin-top: 20px;">
          {copy.values.map(([title, text]) => (
            <div class="why-item">
              <h3>{title}</h3>
              <p>{text}</p>
            </div>
          ))}
        </div>
        <p style="margin-top: 34px;">
          <a href={waLink(lang)} class="btn btn-wa" target="_blank" rel="noopener">{copy.cta}</a>
        </p>
      </div>
      <div>
        <img src="/images/kaindy.jpg" alt={lang === 'en' ? 'Lake Kaindy sunken forest' : 'Затонувший лес озера Каинды'} loading="lazy" width="640" height="480" />
        <img src="/images/assy-plateau.jpg" alt={lang === 'en' ? 'Assy-Turgen observatory under the Milky Way' : 'Обсерватория Ассы-Тургень под Млечным Путём'} loading="lazy" width="640" height="480" style="margin-top: 22px;" />
      </div>
    </div>
  </section>
</Base>
