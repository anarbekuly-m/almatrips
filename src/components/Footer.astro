---
import Logo from './Logo.astro';
import { t, localizePath, waLink, WHATSAPP_DISPLAY, INSTAGRAM, BRAND, type Lang } from '../i18n/ui';
import { tours } from '../data/tours';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <a href={localizePath(lang, '/')} class="logo"><Logo /></a>
        <p>{t(lang, 'footer.tagline')}</p>
      </div>
      <div>
        <h4>{t(lang, 'footer.tours')}</h4>
        <ul>
          <li><a href={localizePath(lang, '/group-tours/')}>{t(lang, 'nav.group')}</a></li>
          <li><a href={localizePath(lang, '/private-tours/')}>{t(lang, 'nav.private')}</a></li>
          {tours.map((tour) => (
            <li><a href={localizePath(lang, `/tours/${tour.slug}/`)}>{tour[lang].title}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4>{t(lang, 'footer.contact')}</h4>
        <ul>
          <li><a href={waLink(lang)} target="_blank" rel="noopener">WhatsApp · {WHATSAPP_DISPLAY}</a></li>
          <li><a href={INSTAGRAM} target="_blank" rel="noopener">Instagram</a></li>
          <li>{t(lang, 'footer.city')}</li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© {year} {BRAND}. {t(lang, 'footer.rights')}</span>
      <a href="/credits/">{t(lang, 'footer.credits')}</a>
    </div>
  </div>
</footer>
