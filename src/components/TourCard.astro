---
import { t, localizePath, type Lang } from '../i18n/ui';
import { type Tour } from '../data/tours';
import Slider from './Slider.astro';

interface Props {
  tour: Tour;
  lang: Lang;
}

const { tour, lang } = Astro.props;
const c = tour[lang];
const url = localizePath(lang, `/tours/${tour.slug}/`);
const images = tour.gallery?.length ? tour.gallery : [tour.image];
---
<article class="tour-card">
  <Slider images={images} alt={c.title} href={url} chip={c.duration} class="tour-card-media" />
  <div class="tour-card-body">
    <h3><a href={url}>{c.title}</a></h3>
    <p class="tour-card-teaser">{c.teaser}</p>
    <div class="tour-card-foot">
      <div class="price">
        <strong>{t(lang, 'gt.from')} {tour.priceKzt.toLocaleString('ru-RU')} ₸</strong>
      </div>
      <a href={url} class="btn btn-outline">{t(lang, 'card.details')}</a>
    </div>
  </div>
</article>
